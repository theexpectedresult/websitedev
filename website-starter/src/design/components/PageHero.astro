---
// src/design/components/PageHero.astro
// Header band used by Services + industry pages. Mirrors the pamphlet header:
// left = eyebrow / title / subtitle on the teal gradient; right = company + licence.
import { SITE } from "../../data/site";

interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  /** Show the company + licence block on the right (default true). */
  company?: boolean;
}
const { eyebrow, title, subtitle, company = true } = Astro.props;
---

<section class="hero">
  <div class="container split">
    <div class="left">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      {subtitle && <p class="subtitle">{subtitle}</p>}
    </div>
    {
      company && (
        <div class="right">
          <p class="co">{SITE.legalEntity}</p>
          <p class="co-sub">British Columbia, Canada</p>
          <p class="co-tags">Security · AV · Networks · Automation</p>
          <p class="co-lic">{SITE.licenses.join(" · ")}</p>
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    background: var(--grad-header-left);
    color: #eafdfb;
  }
  .split {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 28px;
    align-items: center;
    padding: 48px 0;
  }
  .eyebrow {
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #8fd8d0;
    font-weight: 600;
    margin: 0 0 6px;
  }
  h1 {
    font-size: 46px;
    line-height: 1.04;
    color: #fff;
    margin: 0;
  }
  .subtitle {
    color: #a8e3dd;
    font-size: 19px;
    font-weight: 500;
    margin: 8px 0 0;
  }
  .right {
    text-align: right;
    border-left: 1px solid rgba(255, 255, 255, 0.16);
    padding-left: 28px;
  }
  .co {
    font-weight: 700;
    font-size: 16px;
    color: #fff;
    margin: 0;
  }
  .co-sub,
  .co-tags {
    font-size: 13px;
    color: #cfdae4;
    margin: 2px 0 0;
  }
  .co-lic {
    font-size: 11.5px;
    color: #9fb3c0;
    margin: 6px 0 0;
    line-height: 1.4;
  }
  @media (max-width: 820px) {
    .split {
      grid-template-columns: 1fr;
      padding: 36px 0;
    }
    h1 {
      font-size: 36px;
    }
    .right {
      text-align: left;
      border-left: 0;
      padding-left: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.16);
      padding-top: 16px;
    }
  }
</style>
