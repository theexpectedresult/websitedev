---
// src/design/components/QuoteForm.astro
// Walkthrough request form → SITE.formEndpoint (static; no backend).
// Web3Forms by default (needs SITE.formAccessKey); also sends Formspree's
// _next/_gotcha fields so a Formspree endpoint works with no other change.
import { SITE } from "../../data/site";

const endpoint = SITE.formEndpoint;
const accessKey = SITE.formAccessKey ?? "";
const usingWeb3Forms = endpoint.includes("web3forms");
// Ready when the endpoint is real AND (if Web3Forms) the access key is filled in.
const keyMissing = usingWeb3Forms && (!accessKey || accessKey.startsWith("REPLACE"));
const endpointReady = !endpoint.startsWith("REPLACE") && !keyMissing;
const redirectUrl = `${SITE.domain}/quote/?sent=1`;
const subject = "New walkthrough request — ER Tech Services";

const types = ["Restaurant", "Retail", "Pet store", "Office", "Clinic", "Other"];
---

<form
  class="qform"
  method="POST"
  action={endpointReady ? endpoint : undefined}
>
  {/* Web3Forms credential (only when using Web3Forms) */}
  {usingWeb3Forms && <input type="hidden" name="access_key" value={accessKey} />}
  {/* Email subject: Web3Forms reads `subject`, Formspree reads `_subject` */}
  <input type="hidden" name="subject" value={subject} />
  <input type="hidden" name="_subject" value={subject} />
  {/* Redirect after submit: Web3Forms reads `redirect`, Formspree reads `_next` */}
  <input type="hidden" name="redirect" value={redirectUrl} />
  <input type="hidden" name="_next" value={redirectUrl} />
  {/* Honeypots (kept off-screen): Web3Forms `botcheck`, Formspree `_gotcha` */}
  <input type="text" name="_gotcha" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <input type="checkbox" name="botcheck" class="hp" tabindex="-1" aria-hidden="true" />

  <div class="row two">
    <label>
      <span>Name</span>
      <input type="text" name="name" required autocomplete="name" />
    </label>
    <label>
      <span>Phone</span>
      <input type="tel" name="phone" autocomplete="tel" />
    </label>
  </div>

  <div class="row two">
    <label>
      <span>Email</span>
      <input type="email" name="email" required autocomplete="email" />
    </label>
    <label>
      <span>Business type</span>
      <select name="type">
        {types.map((t) => <option value={t}>{t}</option>)}
      </select>
    </label>
  </div>

  <label class="row">
    <span>What are you looking to do?</span>
    <textarea
      name="message"
      rows="5"
      placeholder="Tell us about your space and what you need — security, cameras, network, AV…"
    ></textarea>
  </label>

  <div class="actions">
    <button type="submit" class="submit" disabled={!endpointReady}>
      Request my walkthrough
    </button>
    <p class="fineprint">
      We'll reply from {SITE.email}. No street visit obligation — it's a conversation first.
    </p>
  </div>

  {
    !endpointReady && (
      <p class="endpoint-warn">
        ⚠ Form not enabled yet — paste your Web3Forms access key into
        <code>SITE.formAccessKey</code> in <code>src/data/site.ts</code> (free key at
        web3forms.com), then rebuild. Until then, submissions are disabled.
      </p>
    )
  }
</form>

<style>
  .qform {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .hp {
    position: absolute !important;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .row.two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  label > span {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    color: #2a3744;
  }
  input,
  select,
  textarea {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 9px;
    padding: 11px 13px;
    width: 100%;
  }
  input:focus,
  select:focus,
  textarea:focus {
    outline: 3px solid var(--brand);
    outline-offset: 1px;
    border-color: var(--brand);
  }
  textarea {
    resize: vertical;
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .submit {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    color: #08231f;
    background: var(--brand);
    border: 0;
    border-radius: 10px;
    padding: 13px 24px;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(57, 198, 192, 0.35);
  }
  .submit:hover:not(:disabled) {
    background: #57d6d0;
  }
  .submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .fineprint {
    font-size: 13px;
    color: #5a6675;
    margin: 0;
    max-width: 42ch;
  }
  .endpoint-warn {
    font-size: 13px;
    color: #8a3a90;
    background: #f7edf8;
    border: 1px solid #e3c8e6;
    border-radius: 8px;
    padding: 10px 12px;
    margin: 0;
  }
  .endpoint-warn code {
    font-family: ui-monospace, Consolas, monospace;
    font-size: 0.92em;
  }
  @media (max-width: 560px) {
    .row.two {
      grid-template-columns: 1fr;
    }
  }
</style>
