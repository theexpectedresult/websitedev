---
// src/design/components/Masthead.astro
// Site header. Wordmark + legal-entity line + primary nav, all from site.ts.
// Wordmark matches the pamphlet footer: ER [Tech in --brand] Services.
import { SITE } from "../../data/site";
import BrandMark from "./BrandMark.astro";

// Split the brand string around the accent word so "Tech" renders in --brand.
const accent = SITE.brandAccentWord;
const [before, after] = SITE.brand.split(accent);

// Normalise the current path for active-state matching (trailing slash tolerant).
const here = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) => {
  const h = href.replace(/\/+$/, "") || "/";
  return h === "/" ? here === "/" : here === h || here.startsWith(h + "/");
};
---

<header class="masthead">
  <div class="container bar">
    <a class="brandblock" href="/" aria-label={`${SITE.brand} — home`}>
      <BrandMark size={42} />
      <span class="brandtext">
        <span class="wordmark">{before}<span class="accent">{accent}</span>{after}</span>
        <span class="legal">{SITE.legalEntity}</span>
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav" aria-label="Primary">
      <ul>
        {
          SITE.nav.map((item) => (
            <li>
              <a
                href={item.href}
                class={[
                  "cta" in item && item.cta ? "navcta" : "navlink",
                  isActive(item.href) ? "is-active" : "",
                ].join(" ")}
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .masthead {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--grad-header-left);
    color: #eafdfb;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    min-height: 76px;
    padding: 12px 0;
  }

  /* ---- brand logo ---- */
  .brandblock {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 14px;
    color: inherit;
    text-decoration: none;
  }
  .brandblock:hover {
    text-decoration: none;
  }
  .brandtext {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.05;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    letter-spacing: 0.3px;
    color: #fff;
  }
  .wordmark .accent {
    color: var(--brand);
  }
  .legal {
    font-size: 11.5px;
    letter-spacing: 0.2px;
    color: #bfe3de;
    font-weight: 500;
    max-width: 30ch;
    line-height: 1.2;
  }

  /* ---- nav ---- */
  .nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    padding: 0;
  }
  .navlink,
  .navcta {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15.5px;
    letter-spacing: 0.2px;
    text-decoration: none;
    border-radius: 8px;
    padding: 9px 14px;
    display: inline-block;
    white-space: nowrap;
  }
  .navlink {
    color: #d7f1ee;
  }
  .navlink:hover,
  .navlink.is-active {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    text-decoration: none;
  }
  .navcta {
    color: #08231f;
    background: var(--brand);
    box-shadow: 0 2px 10px rgba(57, 198, 192, 0.35);
  }
  .navcta:hover {
    background: #57d6d0;
    text-decoration: none;
  }

  /* ---- mobile ---- */
  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
  }
  .nav-burger span {
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .nav-burger {
      display: flex;
    }
    .legal {
      display: none;
    }
    .nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--grad-header-left);
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }
    .nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 4px;
      padding: 12px;
    }
    .navlink,
    .navcta {
      display: block;
      text-align: center;
    }
    .nav-toggle:checked ~ .nav {
      max-height: 420px;
    }
  }
</style>
