---
// src/design/components/SmaTiers.astro
// Service & Maintenance Agreement tier strip: Standard / Priority / Premium.
// Premium is gold-highlighted. Content from services.ts (no copy drift).
import { smaTiers, smaNote } from "../../data/services";

interface Props {
  /** Show the "SMA clients always jump the queue" note (default true). */
  note?: boolean;
  /** Lead line above the strip (default the pamphlet wording). */
  lead?: string;
}

const {
  note = true,
  lead = "Service & Maintenance Agreement (SMA) — choose your response tier:",
} = Astro.props;

const badgeClass: Record<string, string> = {
  Standard: "b-std",
  Priority: "b-pri",
  Premium: "b-prem",
};
---

<div class="sma">
  {lead && <p class="sma-lead">{lead}</p>}
  <div class="tiers">
    {
      smaTiers.map((t) => (
        <div class={`tier ${t.premium ? "premium" : ""}`}>
          <div class={`badge ${badgeClass[t.name] ?? ""}`} />
          <div class="body">
            <div class="tname">{t.name}</div>
            <div class="ttime">{t.response}</div>
          </div>
        </div>
      ))
    }
  </div>
  {note && <p class="sma-note">{smaNote}</p>}
</div>

<style>
  .sma-lead {
    font-size: 14px;
    color: #22424f;
    font-weight: 600;
    margin: 0 0 10px;
    line-height: 1.3;
  }
  .tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }
  .tier {
    border: 1px solid #bcd2e2;
    border-radius: 10px;
    background: #fff;
    overflow: hidden;
    text-align: center;
  }
  .badge {
    height: 6px;
  }
  .b-std {
    background: var(--sma-standard);
  }
  .b-pri {
    background: var(--sma-priority);
  }
  .b-prem {
    background: var(--sma-premium);
  }
  .tier .body {
    padding: 12px 8px 14px;
  }
  .tname {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--ink);
  }
  .ttime {
    font-size: 13px;
    color: #1f6d9a;
    font-weight: 600;
    margin-top: 3px;
    line-height: 1.2;
  }
  .tier.premium {
    border-color: var(--sma-premium);
    box-shadow: 0 0 0 1px var(--sma-premium) inset;
  }
  .sma-note {
    font-size: 12.5px;
    color: #4a5a67;
    margin-top: 10px;
    line-height: 1.3;
  }
</style>
